# ===========================================
# Copy this file to `.env.local` and fill in.
# Never commit `.env.local` or real secrets to Git.
# In Vercel: Project → Settings → Environment Variables (same names).
# Optional lines below: leave commented until you need them — that's normal.
# ===========================================

# --- Admin panel (sessions + database) ---
# Required for /admin: iron-session needs 32+ chars. Generate a random string for production.
# SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
# PostgreSQL (Railway, Vercel Postgres, etc.). Run: npx prisma db push && npm run db:seed
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Optional: comma-separated emails that also get admin (in addition to seeded owner in prisma/seed.ts)
# ADMIN_EMAILS=

# --- Your site (Next.js) ---
# Public URL of YOUR new site (no trailing slash). Used for absolute links, SEO, sitemap.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Optional: short site name for metadata / UI
NEXT_PUBLIC_SITE_NAME=Food and Travel Magazine


# --- WordPress (headless / REST API) ---
# Full URL of WordPress on SiteGround — no trailing slash.
# Test in a browser: https://your-wordpress-site.com/wp-json/wp/v2/posts
# Production: https://foodandtravelmagazine.com — REST API must be reachable (test: /wp-json/wp/v2/posts)
WORDPRESS_URL=https://your-wordpress-site.com

# Optional: if WordPress is in a subfolder, set full API base (otherwise leave unset).
# Example: https://example.com/blog/wp-json
# WORDPRESS_API_URL=https://your-wordpress-site.com/wp-json

# Optional: override category slugs for /seasonal-travel-vacation-spots filters.
# Defaults align with foodandtravelmagazine.com seasonal slugs + editorial-features + interviews (create “Interviews” in WP; slug is usually `interviews`).
# WORDPRESS_CAT_SLUG_SPRING=spring-travel-destinations
# WORDPRESS_CAT_SLUG_SUMMER=summer-travel-destinations
# WORDPRESS_CAT_SLUG_FALL=top-fall-destinations
# WORDPRESS_CAT_SLUG_WINTER=winter-travel-destinations
# WORDPRESS_CAT_SLUG_EDITORIALS=editorial-features
# WORDPRESS_CAT_SLUG_INTERVIEWS=interviews

# Only if you fetch *private* or draft posts from the server (not in the browser):
# Create an Application Password in WP: Users → Profile → Application Passwords
# Use the WordPress USERNAME and the generated password (not your normal login password).
# WORDPRESS_USER=your_wp_username
# WORDPRESS_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional: HTTP Basic if SiteGround protects staging with user/pass
# WORDPRESS_HTTP_USER=staging_user
# WORDPRESS_HTTP_PASSWORD=staging_password


# --- Database (only if you use Railway Postgres or similar) ---
# From Railway → Postgres → Connect → "Database URL" (or construct from host/user/pass).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Optional: direct pieces if your ORM wants them instead of one URL
# POSTGRES_HOST=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
# POSTGRES_PORT=5432


# --- On-demand revalidation (optional, Next.js) ---
# Random long secret — you choose it. Used to call /api/revalidate from WordPress after publish.
# REVALIDATION_SECRET=generate-a-long-random-string-here

# Optional: webhook URL is usually on your Next app, e.g. https://yoursite.com/api/revalidate


# --- Draft / Preview (optional) ---
# If you use Next.js draft mode with WordPress preview links
# PREVIEW_SECRET=another-long-random-string


# --- Email / forms (only if you add a provider) ---
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# CONTACT_FORM_TO_EMAIL=hello@yourdomain.com


# --- Analytics (optional) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
