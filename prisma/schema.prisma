generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  name                     String    @default("Admin")
  passwordHash             String
  mustChangePassword       Boolean   @default(true)
  isAdmin                  Boolean   @default(false)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripeSubscriptionStatus String?
  emailVerifiedAt          DateTime?
  phone                    String?
  phoneVerifiedAt          DateTime?
  subscribeConfirmationToken String? @unique
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model EmailListSubscriber {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String    @unique
  emailVerifiedAt   DateTime?
  phone             String?
  phoneVerifiedAt   DateTime?
  confirmationToken String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

/// Issues for /magazines — files live under public/magazines/ and public/magazines/cover-thumbnails/
model Magazine {
  id           String   @id @default(cuid())
  slug         String   @unique
  displayTitle String
  releaseDate  DateTime
  releaseLabel String
  blurb        String   @db.Text
  coverSrc     String
  pdfSrc       String
  purchaseUrl  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([releaseDate])
}

// Admin-editable JSON for /visit/[slug]; overrides bundled defaults when present.
model StateDestinationContent {
  slug      String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/// National list + state “Eat” picks; nationalRank 1–150 for Top Restaurants page (null = not on national list).
model Restaurant {
  id            String   @id @default(cuid())
  name          String
  address       String   @default("")
  email         String   @default("")
  phone         String   @default("")
  website       String   @default("")
  openTableUrl  String   @default("")
  cuisine       String   @default("")
  ownerChef     String   @default("")
  awards        String   @default("—")
  thumbnailUrl  String   @default("") @db.Text
  stateSlug     String   @default("")
  country       String   @default("United States")
  nationalRank  Int?     @unique
  highlights    StateRestaurantHighlight[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([stateSlug])
  @@index([country])
  @@index([cuisine])
}

/// Up to 8 restaurants featured on /visit/[stateSlug] — order by position.
model StateRestaurantHighlight {
  id           String     @id @default(cuid())
  stateSlug    String
  restaurantId String
  position     Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([stateSlug, position])
  @@unique([stateSlug, restaurantId])
  @@index([stateSlug])
}

/// Top Chefs profiles — /top-chefs and /top-chefs/[slug]; editable in admin.
model Chef {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  imageUrl    String   @db.Text
  cuisines    Json
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([name])
}
